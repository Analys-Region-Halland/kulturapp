### Funktion för att snygga till regionnamn (ta bort siffror samt "län" som suffix")

func_rensa_regionnamn <- function(data, regionColumn = "Region") {
  data |>
    mutate(!!regionColumn := str_remove_all(!!sym(regionColumn), "\\d+")) |> # Ta bort siffror
    mutate(!!regionColumn := str_remove_all(!!sym(regionColumn), " län")) |> # Ta bort " län"
    mutate(!!regionColumn := if_else(str_detect(!!sym(regionColumn), "s$"), str_replace(!!sym(regionColumn), "s$", ""), !!sym(regionColumn))) |> # Ta bort "s" i slutet om det är det enda "s" i ordet
    mutate(!!regionColumn := str_trim(!!sym(regionColumn))) # Trimma whitespace
}

### Funktion för att hämta BRP och fastprisberäkna det (bara näringslivet eller hela ekonomin) Hämtar data för samtliga regioner och riket

func_fastpris <- function(basår, näringslivet = TRUE) {
  
  
  if(näringslivet == TRUE) {sektor <-  c("A01-F43","G45-T98")}
  if(näringslivet == FALSE) {sektor <-  c("0002")}
  if(näringslivet == TRUE) {sektor_namn <-  c("Näringslivet")}
  if(näringslivet == FALSE) {sektor_namn <-  c("Hela ekonomin")}
  

## Hämtar volymutveckling
pxweb_query_list <- 
  list("Region"=c(
    "00",
    "01",
    "03",
    "04",
    "05",
    "06",
    "07",
    "08",
    "09",
    "10",
    "12",
    "13",
    "14",
    "17",
    "18",
    "19",
    "20",
    "21",
    "22",
    "23",
    "24",
    "25"),
    "ContentsCode"=c("NR0105AI"),
    "Tid"=c("*"))

px_data <- 
  pxweb_get(url = "https://api.scb.se/OV0104/v1/doris/sv/ssd/START/NR/NR0105/NR0105A/NR0105ENS2010T01A",
            query = pxweb_query_list)

suppressWarnings(volymutveckling <- as.data.frame(px_data))
volymutveckling <- volymutveckling |>
  rename(volymutveckling = `BRP, volymutveckling i procent`) |>
  mutate(volymutveckling = volymutveckling/100+1)

## Hämtar BRP
pxweb_query_list <- 
  list("Region"=c(
    "00",
    "01",
    "03",
    "04",
    "05",
    "06",
    "07",
    "08",
    "09",
    "10",
    "12",
    "13",
    "14",
    "17",
    "18",
    "19",
    "20",
    "21",
    "22",
    "23",
    "24",
    "25"),
    "ContentsCode"=c("NR0105AP",
                     "NR0105AQ"),
    "SNI2007"=sektor,
    "Tid"=c("*"))

px_data <- 
  pxweb_get(url = "https://api.scb.se/OV0104/v1/doris/sv/ssd/START/NR/NR0105/NR0105A/NR0105ENS2010T03A",
            query = pxweb_query_list)
brp_kod <- as.data.frame(px_data, variable.value.type="code") |>
  select("kod" = "region")
brp <- as.data.frame(px_data) |>
  cbind(brp_kod)

brp <- brp |>
  group_by(region, kod, år) |>
  summarize(brp_löpande = sum(`BRP, löpande priser, mnkr`),
            medelantal_sysselsatta = sum(`Medelantal sysselsatta, personer i 1000-tal`), .groups ="drop") |>
  inner_join(volymutveckling, by=c("region", "år"))


brp <- as_tibble(brp)

  
brp_efter_basår <- brp %>% 
    group_by(region) |>
    filter(år >= basår) %>%
    mutate(volymutveckling2 = if_else(år == basår, 1, volymutveckling)) %>%
    mutate(volymutveckling2 = cumprod(volymutveckling2)) |>
  ungroup()
  
brp_innan_basår <- brp %>% 
    group_by(region) |>
    filter(år <= basår) |>
    mutate(volymutveckling2 = lead(volymutveckling)) |>
    filter(år != basår) |>
    arrange(desc(år), .by_group = TRUE) |>
    mutate(volymutveckling2 = cumprod(volymutveckling2)) |>
    arrange(år, .by_group = TRUE) |>
  ungroup()

    
brp_fastpris <- rbind(brp_innan_basår, brp_efter_basår) |>
    group_by(region) |>
    arrange(år, .by_group = TRUE) |>
    mutate(brp_basår = brp_löpande[år == basår]) |>
    ungroup() |>
    mutate(brp_fastprisberäknad = if_else(år >= basår, brp_basår*volymutveckling2, brp_basår/volymutveckling2)) |>
    select(-volymutveckling2, -brp_basår)  |>
    mutate(sektor = sektor_namn)

return(brp_fastpris)
}

### Funktion för att hämta befolkning för alla kommuner, regioner och riket

func_hämta_befolkning <- function() {
  
  pxweb_query_list <- 
    list("Region"=c("*"),
      "ContentsCode"=c("BE0101N1"),
      "Tid"=c("*"))
  
  px_data <- 
    pxweb_get(url = "https://api.scb.se/OV0104/v1/doris/sv/ssd/START/BE/BE0101/BE0101A/BefolkningNy",
              query = pxweb_query_list)
  
  bef_kod <- as.data.frame(px_data, variable.value.type = "code") |>
    select("kod" = "region")
  bef <- as.data.frame(px_data) |>
    cbind(bef_kod) |>
    mutate(geografi = case_when(region == "Riket" ~ "Riket",
                              str_length(kod) == 4 ~ "Kommun", 
                              TRUE ~ "Region"))
  
  return(bef)
}

