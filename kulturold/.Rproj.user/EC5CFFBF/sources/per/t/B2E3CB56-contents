### Funktion för att hämta flyttkomponenter för alla kommuner, regioner och riket

func_hämta_flyttkomponenter <- function() {
  
  
  ## In- och utrikes flyttning
  pxweb_query_list <- 
    list("Region"=c("*"),
         "ContentsCode"=c("BE0101AX",
                          "BE0101AY",
                          "BE0101A1",
                          "BE0101A2",
                          "BE0101A3",
                          "BE0101A4"),
         "Tid"=c("*"))
  
  px_data <- 
    pxweb_get(url = "https://api.scb.se/OV0104/v1/doris/sv/ssd/START/BE/BE0101/BE0101J/Flyttningar97",
              query = pxweb_query_list)
  
  flytt_kod <- as.data.frame(px_data, variable.value.type = "code") |>
    select("kod" = "region")
  flytt <- as.data.frame(px_data) |>
    cbind(flytt_kod) |>
    filter(kod != "0010", kod != "0020", kod != "0030") |>
    pivot_longer(3:8, names_to="komponent", values_to ="värde")
  
  ## Födda
  pxweb_query_list <- 
    list("Region"=c("*"),
         "ContentsCode"=c("BE0101E2"),
         "Tid"=c("*"))
  
  px_data <- 
    pxweb_get(url = "https://api.scb.se/OV0104/v1/doris/sv/ssd/START/BE/BE0101/BE0101H/FoddaK",
              query = pxweb_query_list)
  
  födda_kod <- as.data.frame(px_data, variable.value.type = "code") |>
    select("kod" = "region")
  födda <- as.data.frame(px_data) |>
    cbind(födda_kod) |>
    rename(Födda = `Levande födda`)
  
  ## Döda
  pxweb_query_list <- 
    list("Region"=c("*"),
         "ContentsCode"=c("BE0101D8"),
         "Tid"=c("*"))
  
  px_data <- 
    pxweb_get(url = "https://api.scb.se/OV0104/v1/doris/sv/ssd/START/BE/BE0101/BE0101I/DodaFodelsearK",
              query = pxweb_query_list)
  
  döda_kod <- as.data.frame(px_data, variable.value.type = "code") |>
    select("kod" = "region")
  döda <- as.data.frame(px_data) |>
    cbind(döda_kod)
    
  ## Födelseöverskott
  födelseöverskott <-
    left_join(födda, döda, by = c("region", "år", "kod")) |>
    mutate(Födelseöverskott = Födda - Döda) |>
    pivot_longer(cols=c(Födda, Döda, Födelseöverskott), names_to = "komponent", values_to="värde")
  
  ## Binder data
  data <- rbind(flytt, födelseöverskott) |>
    mutate(geografi = case_when(region == "Riket" ~ "Riket",
                                str_length(kod) == 4 ~ "Kommun", 
                                TRUE ~ "Region"))
  
  return(data)
  
}

