tema <- function(){
theme_minimal() +
theme(
plot.background = element_blank(),
panel.background = element_rect(fill = "white", color = NA),
panel.grid = element_blank(),
legend.position = "right",
legend.text = element_text(
size = 10,
family = "Poppins"),
plot.title = element_text(
size = 12,
color = "#001B22",
face = "bold",
family = "Poppins",
margin = margin(b = 4, t=4)
),
plot.subtitle = element_text(
size = 10,
color = "#001B22",
family = "Poppins",
margin = margin(b = 4)
),
plot.caption = element_text(
size = 8,
color = "#666666",
family = "Poppins",
margin = margin(t = 10)
),
axis.text = element_text(
size = 9,
color = "#001B22",
family = "Poppins"
),
axis.title = element_text(
size = 8.5,
color = "#666666",
family = "Poppins"
),
axis.line = element_line(color = "#001B22", linewidth = 0.2),
axis.ticks = element_line(color = "#001B22", linewidth = 0.2),
axis.ticks.length = unit(0.1, "cm"),
plot.margin = margin(1, 1, 1, 1),
strip.text = element_text(
color= "#001B22",
family="Poppins",
size=8,
face="bold"
))
}
